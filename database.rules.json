{
  "rules": {
    ".read": true,
    ".write": true,
    "teachers": {
      ".indexOn": ["username", "email"]
    },
    "students": {
      ".indexOn": ["studentId", "email"]
    },
    "studentScores": {
      ".indexOn": ["studentId", "examDate"]
    },
    "questions": {
      ".indexOn": ["targetClass"]
    },
    "materials": {
      ".indexOn": ["targetClass", "type"]
    },
    "tests": {
      ".indexOn": ["targetClass", "examDate"]
    }
  }
}
